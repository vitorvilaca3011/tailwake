# ═══════════════════════════════════════════════════════════════════════════════
# tailwake configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to tailwake.env (or ~/.config/tailwake/tailwake.env) and edit.
# tailwake.env is gitignored — your secrets stay local.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Relay device (Android/Termux, Raspberry Pi, Linux box, etc.) ──────────────
RELAY_USER="termux_user"           # SSH username on the relay
RELAY_HOST="100.x.x.x"             # Tailscale IP or hostname of the relay
RELAY_PORT="8022"                  # SSH port (default Termux: 8022, Linux: 22)

# ── Target desktop (the machine you want to wake up) ──────────────────────────
DESKTOP_MAC="AA:BB:CC:DD:EE:FF"    # Ethernet MAC address
DESKTOP_IP="192.168.1.100"         # Local IP address
BROADCAST="192.168.1.255"          # LAN broadcast address
WOL_PORT="9"                       # Wake-on-LAN UDP port (default: 9)

# ── Sunshine (game streaming, optional) ───────────────────────────────────────
SUNSHINE_HOST="${DESKTOP_IP}"      # Sunshine host (usually the desktop)
SUNSHINE_PORT="47990"              # Sunshine TCP port (default: 47990)

# ── Timeouts ──────────────────────────────────────────────────────────────────
WAIT_TIMEOUT="180"                 # Max seconds waiting for Sunshine
WAIT_INTERVAL="5"                  # Seconds between checks
BOOT_GRACE_SECONDS="30"            # Delay after WoL before checking
